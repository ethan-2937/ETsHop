	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="com.etshop.entity.query.ProductSkuQuery">
		 UPDATE product_sku p
 		 <set> 
			<if test="bean.productId != null">
				 product_id = #{bean.productId},
			</if>
			<if test="bean.propertyValueIdHash != null">
				 property_value_id_hash = #{bean.propertyValueIdHash},
			</if>
			<if test="bean.propertyValueIds != null">
				 property_value_ids = #{bean.propertyValueIds},
			</if>
			<if test="bean.price != null">
				 price = #{bean.price},
			</if>
			<if test="bean.stock != null">
				 stock = #{bean.stock},
			</if>
			<if test="bean.sort != null">
				 sort = #{bean.sort},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete p from product_sku p
 		 <include refid="query_condition" />
	</delete>

	<!-- 根据ProductIdAndPropertyValueIdHash修改-->
	<update id="updateByProductIdAndPropertyValueIdHash" parameterType="com.etshop.entity.po.ProductSku">
		 UPDATE product_sku
 		 <set> 
			<if test="bean.propertyValueIds != null">
				 property_value_ids = #{bean.propertyValueIds},
			</if>
			<if test="bean.price != null">
				 price = #{bean.price},
			</if>
			<if test="bean.stock != null">
				 stock = #{bean.stock},
			</if>
			<if test="bean.sort != null">
				 sort = #{bean.sort},
			</if>
 		 </set>
 		 where product_id=#{productId} and property_value_id_hash=#{propertyValueIdHash}
	</update>

	<!-- 根据ProductIdAndPropertyValueIdHash删除-->
	<delete id="deleteByProductIdAndPropertyValueIdHash">
		delete from product_sku where product_id=#{productId} and property_value_id_hash=#{propertyValueIdHash}
	</delete>

	<!-- 根据PrimaryKey获取对象-->
	<select id="selectByProductIdAndPropertyValueIdHash" resultMap="base_result_map" >
		select <include refid="base_column_list" /> from product_sku p where product_id=#{productId} and property_value_id_hash=#{propertyValueIdHash}
	</select>

	<delete id="deleteBatch">
		delete from product_sku where product_id= #{productId} and property_value_id_hash in
		<foreach item="item" collection="dataList" separator="," close=")" open="(">
			#{item.propertyValueIdHash}
		</foreach>
	</delete>

	<update id="updateBatch">
		<foreach item="item" collection="dataList" separator=";">
			update product_sku set
			price=#{item.price}
			where product_id=#{item.productId} and property_value_id_hash=#{item.propertyValueIdHash}
		</foreach>
	</update>
</mapper>