			<if test="bean.stock!=null">
				 #{bean.stock},
			</if>
			<if test="bean.sort!=null">
				 #{bean.sort},
			</if>
		 </trim>
		 on DUPLICATE key update 
		 <trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.productId!=null">
				 product_id = VALUES(product_id),
			</if>
			<if test="bean.propertyValueIdHash!=null">
				 property_value_id_hash = VALUES(property_value_id_hash),
			</if>
			<if test="bean.propertyValueIds!=null">
				 property_value_ids = VALUES(property_value_ids),
			</if>
			<if test="bean.price!=null">
				 price = VALUES(price),
