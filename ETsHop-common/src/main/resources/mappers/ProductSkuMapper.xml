			<if test="bean.stock!=null">
				 stock = VALUES(stock),
			</if>
			<if test="bean.sort!=null">
				 sort = VALUES(sort),
			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="com.etshop.entity.po.ProductSku">
		 INSERT INTO product_sku(
			 product_id,
			 property_value_id_hash,
			 property_value_ids,
			 price,
			 stock,
			 sort
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.productId},
				 #{item.propertyValueIdHash},
				 #{item.propertyValueIds},
				 #{item.price},
				 #{item.stock},
				 #{item.sort}
			 )
		 </foreach>
	</insert>

	<!-- 批量新增修改 （批量插入）-->
	<insert id="insertOrUpdateBatch" parameterType="com.etshop.entity.po.ProductSku">
		 INSERT INTO product_sku(
			 product_id,
			 property_value_id_hash,
			 property_value_ids,
			 price,
			 stock,
			 sort
		 )values
		 <foreach collection="list" item="item" separator=",">
