<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.etshop.mappers.ProductSkuMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.etshop.entity.po.ProductSku">
		<!--商品ID-->
		<result column="product_id" property="productId"  />
		<!--属性值id组hash-->
		<result column="property_value_id_hash" property="propertyValueIdHash"  />
		<!--属性值id组-->
		<result column="property_value_ids" property="propertyValueIds"  />
		<!--价格-->
		<result column="price" property="price"  />
		<!--库存-->
		<result column="stock" property="stock"  />
		<!--排序-->
		<result column="sort" property="sort"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 p.product_id,p.property_value_id_hash,p.property_value_ids,p.price,p.stock,
		 p.sort
	</sql>

	<sql id="base_condition_filed">
			<if test="query.productId != null and query.productId!=''">
				 and  p.product_id = #{query.productId}
			</if>
			<if test="query.propertyValueIdHash != null and query.propertyValueIdHash!=''">
				 and  p.property_value_id_hash = #{query.propertyValueIdHash}
			</if>
			<if test="query.propertyValueIds != null and query.propertyValueIds!=''">
				 and  p.property_value_ids = #{query.propertyValueIds}
			</if>
			<if test="query.price != null">
				 and  p.price = #{query.price}
			</if>
			<if test="query.stock != null">
				 and  p.stock = #{query.stock}
			</if>
			<if test="query.sort != null">
				 and  p.sort = #{query.sort}
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.productIdFuzzy!= null  and query.productIdFuzzy!=''">
				 and  p.product_id like concat('%', #{query.productIdFuzzy}, '%')
			</if>
			<if test="query.propertyValueIdHashFuzzy!= null  and query.propertyValueIdHashFuzzy!=''">
				 and  p.property_value_id_hash like concat('%', #{query.propertyValueIdHashFuzzy}, '%')
			</if>
			<if test="query.propertyValueIdsFuzzy!= null  and query.propertyValueIdsFuzzy!=''">
				 and  p.property_value_ids like concat('%', #{query.propertyValueIdsFuzzy}, '%')
			</if>
			<if test="query.productIdList!=null and query.productIdList.size()>0">
				 and  p.product_id in
				 <foreach collection="query.productIdList" item="item" open="(" close=")" separator=",">
					 #{item}
				 </foreach>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM product_sku p <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM product_sku p <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="com.etshop.entity.po.ProductSku">
		 INSERT INTO product_sku
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.productId != null">
				 product_id,
			</if>
			<if test="bean.propertyValueIdHash != null">
				 property_value_id_hash,
			</if>
			<if test="bean.propertyValueIds != null">
				 property_value_ids,
			</if>
			<if test="bean.price != null">
				 price,
			</if>
			<if test="bean.stock != null">
				 stock,
			</if>
			<if test="bean.sort != null">
				 sort,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.productId!=null">
				 #{bean.productId},
			</if>
			<if test="bean.propertyValueIdHash!=null">
				 #{bean.propertyValueIdHash},
			</if>
			<if test="bean.propertyValueIds!=null">
				 #{bean.propertyValueIds},
			</if>
			<if test="bean.price!=null">
				 #{bean.price},
			</if>
			<if test="bean.stock!=null">
				 #{bean.stock},
			</if>
			<if test="bean.sort!=null">
				 #{bean.sort},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="com.etshop.entity.po.ProductSku">
		 INSERT INTO product_sku
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.productId != null">
				 product_id,
			</if>
			<if test="bean.propertyValueIdHash != null">
				 property_value_id_hash,
			</if>
			<if test="bean.propertyValueIds != null">
				 property_value_ids,
			</if>
			<if test="bean.price != null">
				 price,
			</if>
			<if test="bean.stock != null">
				 stock,
			</if>
			<if test="bean.sort != null">
				 sort,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.productId!=null">
				 #{bean.productId},
			</if>
			<if test="bean.propertyValueIdHash!=null">
				 #{bean.propertyValueIdHash},
			</if>
			<if test="bean.propertyValueIds!=null">
				 #{bean.propertyValueIds},
			</if>
			<if test="bean.price!=null">
